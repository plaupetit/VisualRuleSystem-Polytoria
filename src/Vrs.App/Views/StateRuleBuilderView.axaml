<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vrs.App.ViewModels"
             x:Class="Vrs.App.Views.StateRuleBuilderView"
             x:DataType="vm:MainWindowViewModel">
    <Border BorderBrush="#303642"
            BorderThickness="1"
            Background="#111720"
            Padding="8"
            Margin="0,0,0,10">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="State Rule Builder" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="Add State" Command="{Binding AddStateFragmentAtCanvasPositionCommand}"/>
                <Button Content="Add Rule" Command="{Binding AddRuleFragmentAtCanvasPositionCommand}"/>
            </StackPanel>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding StateRuleRows}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:StateRuleRowViewModel">
                            <Border Width="260"
                                    MinHeight="78"
                                    BorderBrush="#3d4a5c"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="8"
                                    Background="#18202a">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding TriggerSummary}" Foreground="#e0b82d" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ConditionSummary}" Foreground="#38b976" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ActionSummary}" Foreground="#3a9de0" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
